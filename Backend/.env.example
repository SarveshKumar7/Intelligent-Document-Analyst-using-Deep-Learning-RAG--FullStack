# Copy to .env and fill values before running

# Supabase project URL (from Project Settings -> API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key (server-side only) - keep secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase anon/public key (only required for client-side operations)
SUPABASE_ANON_KEY=your-anon-public-key

# Flask settings
FLASK_ENV=development
PORT=8080
